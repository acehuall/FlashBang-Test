* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  font-family: Arial, Helvetica, sans-serif;
  background: #000;
}

body {
  position: relative;
}

.app {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  background: #000;
}

.final-image {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0;
  transform: scale(1.02);
  transition:
    opacity 1.2s ease,
    transform 1.8s ease;
  z-index: 1;
  user-select: none;
  -webkit-user-drag: none;
}

.final-image.show {
  opacity: 1;
  transform: scale(1);
}

.flashbang {
  position: fixed;
  inset: 0;
  background: #fff;
  opacity: 0;
  pointer-events: none;
  z-index: 20;
}

.flashbang.active {
  animation: flashbangEffect 1.8s ease forwards;
}

@keyframes flashbangEffect {
  0% {
    opacity: 0;
  }
  8% {
    opacity: 1;
  }
  30% {
    opacity: 1;
  }
  55% {
    opacity: 0.92;
  }
  100% {
    opacity: 0;
  }
}

.start-screen {
  position: fixed;
  inset: 0;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at center, #111 0%, #050505 55%, #000 100%);
  color: #fff;
  z-index: 30;
  opacity: 1;
  transition: opacity 0.5s ease;
}

.start-screen.hide {
  opacity: 0;
  pointer-events: none;
}

.start-card {
  text-align: center;
  padding: 32px;
  max-width: 420px;
}

.start-card h1 {
  margin: 0 0 10px;
  font-size: 2.2rem;
}

.start-card p {
  margin: 0 0 24px;
  font-size: 1rem;
  opacity: 0.85;
}

button {
  border: none;
  border-radius: 12px;
  padding: 14px 24px;
  font-size: 1rem;
  font-weight: 700;
  cursor: pointer;
  background: #fff;
  color: #000;
  transition:
    transform 0.15s ease,
    opacity 0.15s ease;
}

button:hover {
  transform: scale(1.03);
}

button:active {
  transform: scale(0.98);
}
